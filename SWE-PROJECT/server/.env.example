# ── Copy this to .env and fill in your values ────────────────────────────────
# NEVER commit .env — only .env.example

# Server
PORT=5000
NODE_ENV=production

# Security — REQUIRED in production (generate with: openssl rand -hex 64)
JWT_SECRET=

# CORS — comma-separated list of allowed frontend origins
# For Railway monolith, set to your Railway app URL:
#   CLIENT_ORIGIN=https://revindex.up.railway.app
CLIENT_ORIGIN=http://localhost:5173

# SQLite DB path — defaults to server/db/carlog.db
# On Railway with a persistent volume mounted at /data:
#   DB_PATH=/data/carlog.db
DB_PATH=

# App public URL (used in email verification links)
APP_URL=http://localhost:5000

# Email / SMTP (optional — for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=RevIndex <noreply@revindex.app>
